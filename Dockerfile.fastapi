# Productie-image voor "De digitale gids" (FastAPI-frontend, publieke OER-chat).
# Gekoppeld aan fly.toml (`dockerfile = "Dockerfile.fastapi"`). Build-context = repo-root
# (data leeft buiten het subproject). Deploy vanuit de repo-root:
#   flyctl deploy -a digitale-gids --remote-only
# Vereist Fly-secrets: SESSION_SECRET (cookie-signing), ALGEMEEN_WACHTWOORD, ANTHROPIC_API_KEY.
FROM python:3.13-slim

RUN pip install --no-cache-dir uv
WORKDIR /app/validatie_samenwijzer

# Code + vooraf gebouwde validatie.db (in data/) + skills (data/skills)
COPY validatie_samenwijzer/ ./
RUN uv sync --frozen --no-dev

# Read-only referentiedata (oeren + KD-markdown), zoals de Streamlit-image.
COPY oeren/ /app/oeren/
COPY kwalificatiedossiers/ /app/kwalificatiedossiers/

# SESSION_SECRET wordt NIET hier gezet (fail-closed) — het is een Fly-secret, zodat
# cookies niet met een bekend secret getekend worden. BEHEER_ENABLED expliciet uit.
ENV OEREN_PAD=/app/oeren \
    KWALDOSSIERS_PAD=/app/kwalificatiedossiers/pdfs \
    SKILLS_PAD=/app/validatie_samenwijzer/data/skills \
    DB_PATH=/app/validatie_samenwijzer/data/validatie.db \
    BEHEER_ENABLED=false

EXPOSE 8080
CMD ["uv", "run", "--no-dev", "uvicorn", "app_fastapi.main:app", \
     "--host", "0.0.0.0", "--port", "8080"]
